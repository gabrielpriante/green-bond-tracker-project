install.packages("countrycode")  # Uncomment if not yet installed
# install.packages("tidyverse")    # Uncomment if not yet installed
library(tidyverse)
library(countrycode)
library(knitr)
# install.packages("countrycode")  # Uncomment if not yet installed
# install.packages("tidyverse")    # Uncomment if not yet installed
library(tidyverse)
library(countrycode)
library(knitr)
summary_df <- read_csv("data/processed/green_bonds_by_country.csv")
summary_df <- read_csv("C:\Users\gabpe\OneDrive\Documents\src\green-bond-tracker-project\data\processed\green_bonds_by_country.csv")
summary_df <- read_csv("data/processed/green_bonds_by_country.csv")
summary_df <- read_csv("../data/processed/green_bonds_by_country.csv")
timeseries_df <- read_csv("../data/processed/green_bonds_timeseries.csv")
cat("Summary table:", nrow(summary_df), "rows\n")
cat("Time series table:", nrow(timeseries_df), "rows\n")
summary_df %>%
head(10) %>%
kable(caption = "First 10 rows of summary table")
regions_df <- summary_df %>% filter(Is_Region == TRUE)
countries_df <- summary_df %>% filter(Is_Region == FALSE)
cat("Countries:", nrow(countries_df), "\n")
cat("Regional aggregates:", nrow(regions_df), "\n\n")
cat("Regional aggregates being separated:\n")
regions_df %>%
select(ISO3, Country) %>%
kable()
countries_df <- countries_df %>%
mutate(
ISO2 = countrycode(
sourcevar = ISO3,
origin = "iso3c",
destination = "iso2c"
)
)
# Check for failed conversions
failed <- countries_df %>% filter(is.na(ISO2))
if (nrow(failed) > 0) {
cat("WARNING:", nrow(failed), "codes failed to convert:\n")
failed %>% select(ISO3, Country) %>% kable()
} else {
cat("All", nrow(countries_df), "country codes converted successfully.\n")
}
# Check for duplicates (two ISO3 codes mapping to the same ISO2)
dupes <- countries_df %>%
group_by(ISO2) %>%
filter(n() > 1)
if (nrow(dupes) > 0) {
cat("\nWARNING: Duplicate ISO2 codes detected:\n")
dupes %>% select(ISO3, ISO2, Country) %>% kable()
} else {
cat("No duplicate ISO2 codes. Each country maps uniquely.\n")
}
countries_df %>%
select(ISO3, ISO2, Country) %>%
slice_sample(n = 15) %>%
arrange(Country) %>%
kable(caption = "Random sample of ISO3 → ISO2 mappings")
countries_export <- countries_df %>%
select(
ISO3,
ISO2,
Country,
Green_2024_USD_B,
Green_Cumulative_USD_B,
First_Year,
Years_Active
)
countries_export %>%
head(15) %>%
kable(digits = 3, caption = "Final country table (first 15 rows)")
timeseries_countries <- timeseries_df %>%
filter(Is_Region == FALSE) %>%
mutate(
ISO2 = countrycode(ISO3, "iso3c", "iso2c")
) %>%
select(ISO3, ISO2, Country, Year, Green_Issuance_USD_B)
timeseries_regions <- timeseries_df %>%
filter(Is_Region == TRUE)
cat("Time series — countries:", nrow(timeseries_countries), "rows\n")
cat("Time series — regions:", nrow(timeseries_regions), "rows\n")
# Verify no failed conversions
ts_failed <- timeseries_countries %>% filter(is.na(ISO2))
cat("Failed time series conversions:", nrow(ts_failed), "\n")
cat("=== FINAL OUTPUT SUMMARY ===\n\n")
cat("Countries file:\n")
cat("  Rows:", nrow(countries_export), "\n")
cat("  Columns:", paste(names(countries_export), collapse = ", "), "\n")
cat("  Countries with 2024 issuance > 0:",
sum(countries_export$Green_2024_USD_B > 0), "\n")
cat("  Total cumulative green issuance: $",
round(sum(countries_export$Green_Cumulative_USD_B), 2), "B\n\n")
cat("Time series file:\n")
cat("  Rows:", nrow(timeseries_countries), "\n")
cat("  Entities:", n_distinct(timeseries_countries$ISO3), "\n")
cat("  Years:", min(timeseries_countries$Year), "to",
max(timeseries_countries$Year), "\n\n")
cat("Regional aggregates file:\n")
cat("  Rows:", nrow(regions_df), "\n")
cat("  Entities:", n_distinct(regions_df$ISO3), "\n")
write_csv(countries_export, "../data/processed/green_bonds_by_country_iso2.csv")
write_csv(timeseries_countries, "../data/processed/green_bonds_timeseries_iso2.csv")
write_csv(regions_df, "../data/processed/green_bonds_regional_aggregates.csv")
cat("Exported:\n")
cat("  data/processed/green_bonds_by_country_iso2.csv —",
nrow(countries_export), "rows\n")
cat("  data/processed/green_bonds_timeseries_iso2.csv —",
nrow(timeseries_countries), "rows\n")
cat("  data/processed/green_bonds_regional_aggregates.csv —",
nrow(regions_df), "rows\n")
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(tidyverse)
library(knitr)
raw <- read_csv("../data/raw/Carbon_Footprint_of_Bank_Loans.csv")
cat("Dimensions:", nrow(raw), "rows ×", ncol(raw), "columns\n")
cat("Countries:", n_distinct(raw$Country), "\n")
cat("Indicators:", n_distinct(raw$Indicator), "\n")
glimpse(raw)
raw %>%
count(CTS_Code, Indicator) %>%
kable(caption = "Rows per indicator variant")
year_cols <- paste0("F", 2005:2018)
availability <- raw %>%
filter(CTS_Code == "ECFLM") %>%
summarise(across(all_of(year_cols), ~sum(!is.na(.)))) %>%
pivot_longer(everything(), names_to = "Year", values_to = "Countries") %>%
mutate(Year = as.integer(str_remove(Year, "F")))
availability %>% kable(caption = "Countries with ECFLM data by year")
ecflm <- raw %>%
filter(CTS_Code == "ECFLM")
cat("Rows after filtering to ECFLM:", nrow(ecflm), "\n")
cat("Countries:", n_distinct(ecflm$Country), "\n")
ecflm_long <- ecflm %>%
select(Country, ISO2, ISO3, all_of(year_cols)) %>%
pivot_longer(
cols = all_of(year_cols),
names_to = "Year",
values_to = "CFBL_Multiplier"
) %>%
mutate(Year = as.integer(str_remove(Year, "F"))) %>%
filter(!is.na(CFBL_Multiplier))
cat("Long-format rows:", nrow(ecflm_long), "\n")
cat("Countries:", n_distinct(ecflm_long$Country), "\n")
cat("Year range:", min(ecflm_long$Year), "to", max(ecflm_long$Year), "\n")
cfbl_summary <- ecflm_long %>%
group_by(Country, ISO2, ISO3) %>%
summarise(
CFBL_2018 = CFBL_Multiplier[Year == 2018],
CFBL_First_Year = min(Year),
CFBL_Years_Reported = n(),
CFBL_Mean = mean(CFBL_Multiplier),
CFBL_Trend = case_when(
n() >= 3 ~ coef(lm(CFBL_Multiplier ~ Year))[2],
TRUE ~ NA_real_
),
.groups = "drop"
) %>%
arrange(desc(CFBL_2018))
cat("Summary table:", nrow(cfbl_summary), "rows\n")
cfbl_summary %>%
head(20) %>%
kable(digits = 2, caption = "Top 20 countries by carbon footprint of bank loans (2018)")
green <- read_csv("../data/processed/green_bonds_by_country.csv") %>%
filter(Is_Region == FALSE)
overlap <- inner_join(
cfbl_summary %>% select(ISO3, Country, CFBL_2018, CFBL_Trend),
green %>% select(ISO3, Green_Cumulative_USD_B, Green_2024_USD_B),
by = "ISO3"
)
cat("Countries with BOTH green bond and carbon footprint data:", nrow(overlap), "\n\n")
overlap %>%
arrange(desc(CFBL_2018)) %>%
kable(digits = 2,
caption = "Countries with both CFBL and green bond data — sorted by carbon intensity")
write_csv(cfbl_summary, "../data/processed/cfbl_by_country.csv")
write_csv(ecflm_long, "../data/processed/cfbl_timeseries.csv")
write_csv(overlap, "../data/processed/cfbl_green_bond_overlap.csv")
cat("Exported:\n")
cat("  ../data/processed/cfbl_by_country.csv —",
nrow(cfbl_summary), "rows\n")
cat("  ../data/processed/cfbl_timeseries.csv —",
nrow(ecflm_long), "rows\n")
cat("  ../data/processed/cfbl_green_bond_overlap.csv —",
nrow(overlap), "rows\n")
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
# install.packages("countrycode")  # Uncomment if not yet installed
library(tidyverse)
library(countrycode)
library(knitr)
raw <- read_csv("../data/raw/Green_Bonds.csv")
cat("Dimensions:", nrow(raw), "rows ×", ncol(raw), "columns\n")
cat("Countries:", n_distinct(raw$Country), "\n")
cat("Indicators:", n_distinct(raw$Indicator), "\n")
raw %>%
count(Indicator) %>%
arrange(desc(n)) %>%
kable(caption = "Available indicators and row counts")
year_cols <- paste0("F", 2006:2024)
green_by_country <- raw %>%
filter(Indicator == "Green Bond Issuances by Country") %>%
select(Country, ISO2, ISO3, all_of(year_cols))
cat("Countries with green bond issuance data:", nrow(green_by_country), "\n")
green_long <- green_by_country %>%
pivot_longer(
cols = all_of(year_cols),
names_to = "Year",
values_to = "Green_Issuance_USD_B"
) %>%
mutate(Year = as.integer(str_remove(Year, "F"))) %>%
replace_na(list(Green_Issuance_USD_B = 0))
cat("Long-format rows:", nrow(green_long), "\n")
imf_green_summary <- green_long %>%
group_by(Country, ISO2, ISO3) %>%
summarise(
IMF_Green_2024_USD_B = sum(Green_Issuance_USD_B[Year == 2024]),
IMF_Green_Cumulative_USD_B = sum(Green_Issuance_USD_B),
IMF_Green_First_Year = ifelse(
any(Green_Issuance_USD_B > 0),
min(Year[Green_Issuance_USD_B > 0]),
NA_integer_
),
IMF_Green_Years_Active = sum(Green_Issuance_USD_B > 0),
.groups = "drop"
) %>%
filter(IMF_Green_Cumulative_USD_B > 0) %>%
arrange(desc(IMF_Green_Cumulative_USD_B))
cat("Countries with any green bond issuance:", nrow(imf_green_summary), "\n")
imf_green_summary %>%
head(20) %>%
kable(digits = 3, caption = "Top 20 green bond issuers (IMF/LSEG data)")
sovereign <- raw %>%
filter(Indicator == "Sovereign Green Bond Issuances") %>%
select(Country, ISO2, ISO3, all_of(year_cols))
sovereign_long <- sovereign %>%
pivot_longer(
cols = all_of(year_cols),
names_to = "Year",
values_to = "Sovereign_Green_USD_B"
) %>%
mutate(Year = as.integer(str_remove(Year, "F"))) %>%
replace_na(list(Sovereign_Green_USD_B = 0))
sovereign_summary <- sovereign_long %>%
group_by(Country, ISO2, ISO3) %>%
summarise(
Sovereign_Green_Cumulative_USD_B = sum(Sovereign_Green_USD_B),
Sovereign_First_Year = ifelse(
any(Sovereign_Green_USD_B > 0),
min(Year[Sovereign_Green_USD_B > 0]),
NA_integer_
),
.groups = "drop"
) %>%
filter(Sovereign_Green_Cumulative_USD_B > 0) %>%
arrange(desc(Sovereign_Green_Cumulative_USD_B))
cat("Countries with sovereign green bonds:", nrow(sovereign_summary), "\n")
sovereign_summary %>%
head(15) %>%
kable(digits = 3, caption = "Top 15 sovereign green bond issuers")
imf_combined <- imf_green_summary %>%
left_join(
sovereign_summary %>%
select(ISO3, Sovereign_Green_Cumulative_USD_B, Sovereign_First_Year),
by = "ISO3"
) %>%
replace_na(list(Sovereign_Green_Cumulative_USD_B = 0)) %>%
mutate(
Sovereign_Share_Pct = round(
Sovereign_Green_Cumulative_USD_B / IMF_Green_Cumulative_USD_B * 100, 1
)
)
cat("Final combined table:", nrow(imf_combined), "countries\n")
imf_combined %>%
head(20) %>%
kable(digits = 3,
caption = "Top 20 — total green issuance with sovereign share")
wb <- read_csv("../data/processed/green_bonds_by_country.csv") %>%
filter(Is_Region == FALSE)
imf_iso3 <- imf_combined$ISO3
wb_iso3 <- wb$ISO3
cat("=== COVERAGE COMPARISON ===\n")
cat("IMF/LSEG countries:", length(imf_iso3), "\n")
cat("World Bank/IFC countries:", length(wb_iso3), "\n")
cat("In both:", length(intersect(imf_iso3, wb_iso3)), "\n")
cat("Only in IMF:", length(setdiff(imf_iso3, wb_iso3)), "\n")
cat("Only in World Bank:", length(setdiff(wb_iso3, imf_iso3)), "\n")
cat("Combined unique countries:", length(union(imf_iso3, wb_iso3)), "\n")
write_csv(imf_combined, "../data/processed/imf_green_bonds_by_country.csv")
write_csv(green_long, "../data/processed/imf_green_bonds_timeseries.csv")
cat("Exported:\n")
cat("  ../data/processed/imf_green_bonds_by_country.csv —",
nrow(imf_combined), "rows\n")
cat("  ../data/processed/imf_green_bonds_timeseries.csv —",
nrow(green_long), "rows\n")
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
# install.packages("countrycode")  # Uncomment if not yet installed
library(tidyverse)
library(countrycode)
library(knitr)
raw <- read_csv("../data/raw/bonds_export.csv")
cat("Dimensions:", nrow(raw), "rows ×", ncol(raw), "columns\n")
cat("Unique issuers:", n_distinct(raw$`Issuer / Applicant`), "\n")
cat("Unique countries:", n_distinct(raw$`Issuer Country`, na.rm = TRUE), "\n")
cat("Total bonds/loans:", nrow(raw), "\n")
glimpse(raw)
# Check for null countries
null_countries <- sum(is.na(raw$`Issuer Country`))
cat("Rows with missing country:", null_countries, "\n\n")
# List all unique country names
cat("All unique country names:\n")
sort(unique(raw$`Issuer Country`[!is.na(raw$`Issuer Country`)])) %>%
paste("  ", .) %>%
cat(sep = "\n")
cbi <- raw %>%
mutate(
`Issuer Country` = case_when(
`Issuer Country` == "UAE" ~ "United Arab Emirates",
`Issuer Country` == "Hong KongGermany" ~ "Hong Kong",
`Issuer Country` == "Hong KongChina" ~ "Hong Kong",
`Issuer Country` == "Ivory Coast" ~ "Cote d'Ivoire",
`Issuer Country` == "South Korea" ~ "Korea, Republic of",
TRUE ~ `Issuer Country`
)
) %>%
# Remove rows that aren't assignable to a single country
filter(
!is.na(`Issuer Country`),
!`Issuer Country` %in% c(
"Europe",
"No single country  covers the European Economic Area"
)
)
cat("Rows after cleaning:", nrow(cbi), "\n")
cat("Unique countries after cleaning:", n_distinct(cbi$`Issuer Country`), "\n")
cbi <- cbi %>%
mutate(
ISO2 = countrycode(
`Issuer Country`, origin = "country.name", destination = "iso2c"
),
ISO3 = countrycode(
`Issuer Country`, origin = "country.name", destination = "iso3c"
)
)
# Check for failed conversions
failed <- cbi %>% filter(is.na(ISO2))
if (nrow(failed) > 0) {
cat("WARNING: Failed to convert", n_distinct(failed$`Issuer Country`),
"country names:\n")
failed %>% distinct(`Issuer Country`) %>% pull() %>% cat(sep = "\n")
} else {
cat("All country names converted successfully.\n")
}
cbi <- cbi %>%
mutate(
ISO2 = countrycode(
`Issuer Country`, origin = "country.name", destination = "iso2c"
),
ISO3 = countrycode(
`Issuer Country`, origin = "country.name", destination = "iso3c"
)
)
# Check for failed conversions
failed <- cbi %>% filter(is.na(ISO2))
if (nrow(failed) > 0) {
cat("WARNING: Failed to convert", n_distinct(failed$`Issuer Country`),
"country names:\n")
failed %>% distinct(`Issuer Country`) %>% pull() %>% cat(sep = "\n")
} else {
cat("All country names converted successfully.\n")
}
cbi %>%
count(Status) %>%
kable(caption = "Bond status distribution")
cbi <- cbi %>%
mutate(Size_USD_B = `Size (USD equivalent)` / 1e9)
cat("Bonds with non-zero size:", sum(cbi$Size_USD_B > 0, na.rm = TRUE), "\n")
cat("Bonds with zero or NA size:", sum(cbi$Size_USD_B == 0 | is.na(cbi$Size_USD_B)), "\n")
cat("Total value (non-zero):", round(sum(cbi$Size_USD_B[cbi$Size_USD_B > 0],
na.rm = TRUE), 2), "B USD\n")
cbi <- cbi %>%
mutate(
Sector_Clean = `Sector Criteria` %>%
str_replace_all("\\s{2,}", " ") %>%
str_trim()
)
# For multi-sector bonds, extract the primary (first listed) sector
cbi <- cbi %>%
mutate(
Primary_Sector = str_extract(Sector_Clean, "^[A-Za-z ]+") %>%
str_trim() %>%
str_to_title()
)
cbi %>%
count(Primary_Sector) %>%
arrange(desc(n)) %>%
head(12) %>%
kable(caption = "Bonds by primary sector")
cbi_by_country <- cbi %>%
group_by(`Issuer Country`, ISO2, ISO3) %>%
summarise(
CBI_Bond_Count = n(),
CBI_Total_USD_B = sum(Size_USD_B, na.rm = TRUE),
CBI_Unique_Issuers = n_distinct(`Issuer / Applicant`),
CBI_First_Issue = min(`Issue date`, na.rm = TRUE),
CBI_Latest_Issue = max(`Issue date`, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(desc(CBI_Total_USD_B))
cat("Countries:", nrow(cbi_by_country), "\n")
cbi_by_country %>%
head(20) %>%
kable(digits = 3, caption = "Top 20 countries by CBI-certified green bond value")
cbi_by_sector <- cbi %>%
group_by(Primary_Sector) %>%
summarise(
Bond_Count = n(),
Total_USD_B = sum(Size_USD_B, na.rm = TRUE),
Countries = n_distinct(ISO3),
.groups = "drop"
) %>%
arrange(desc(Total_USD_B))
cbi_by_sector %>%
kable(digits = 3, caption = "CBI-certified bonds by sector (global)")
cbi_country_sector <- cbi %>%
group_by(ISO2, ISO3, `Issuer Country`, Primary_Sector) %>%
summarise(
Bond_Count = n(),
Total_USD_B = sum(Size_USD_B, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(ISO3, desc(Total_USD_B))
cat("Country × Sector combinations:", nrow(cbi_country_sector), "\n")
write_csv(cbi_by_country, "../data/processed/cbi_by_country.csv")
write_csv(cbi_by_sector, "../data/processed/cbi_by_sector.csv")
write_csv(cbi_country_sector, "../data/processed/cbi_country_sector.csv")
cat("Exported:\n")
cat("  ../data/processed/cbi_by_country.csv —",
nrow(cbi_by_country), "rows\n")
cat("  ../data/processed/cbi_by_sector.csv —",
nrow(cbi_by_sector), "rows\n")
cat("  ../data/processed/cbi_country_sector.csv —",
nrow(cbi_country_sector), "rows\n")
